# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/helpmate?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT 配置（生产环境必须替换为随机强密钥，至少32字符）
JWT_SECRET=replace-this-with-a-random-secret-key-at-least-32-chars

# AI 服务配置
AI_API_KEY=your_siliconflow_api_key_here
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=Qwen/Qwen2.5-7B-Instruct
